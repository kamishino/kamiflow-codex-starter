# Base Codex execution policy for all Kami Flow contexts.
# Profile-specific files extend this baseline.
# Anti-pattern references: AP-003, AP-004, AP-005, AP-006

# AP-003/SSOT sync path.
prefix_rule(
  decision = "allow",
  pattern = ["npm", "run", "codex:setup"],
  match = ["npm run codex:setup"],
  not_match = ["npm run codex:sync"]
)

# AP-003/SSOT sync path.
prefix_rule(
  decision = "allow",
  pattern = ["npm", "run", "codex:sync"],
  match = ["npm run codex:sync -- --scope project"],
  not_match = ["pnpm run codex:sync"]
)

# AP-003/Rules sync path.
prefix_rule(
  decision = "allow",
  pattern = ["npm", "run", "codex:sync:rules"],
  match = ["npm run codex:sync:rules -- --scope project --profile dogfood --force"],
  not_match = ["npm run codex:sync:skills -- --force"]
)

# AP-003/Skills sync path.
prefix_rule(
  decision = "allow",
  pattern = ["npm", "run", "codex:sync:skills"],
  match = ["npm run codex:sync:skills -- --force"],
  not_match = ["npm run codex:sync:rules -- --scope repo --force"]
)

# AP-006/ensure-plan primary recovery path.
prefix_rule(
  decision = "allow",
  pattern = ["kfc", "flow", "ensure-plan"],
  match = ["kfc flow ensure-plan --project ."],
  not_match = ["kfc flow next --project . --plan PLAN-1"]
)

prefix_rule(
  decision = "allow",
  pattern = ["kfc", "flow", "next"],
  match = ["kfc flow next --project . --plan PLAN-1 --style narrative"],
  not_match = ["kfc flow ensure-plan --project ."]
)

prefix_rule(
  decision = "allow",
  pattern = ["kfc", "flow", "apply"],
  match = ["kfc flow apply --project . --plan PLAN-1 --route build --result progress"],
  not_match = ["kfc flow next --project . --plan PLAN-1"]
)

prefix_rule(
  decision = "prompt",
  pattern = ["npm", "link"],
  match = ["npm link"],
  not_match = ["npm unlink"]
)

prefix_rule(
  decision = "prompt",
  pattern = ["npm", "unlink"],
  match = ["npm unlink"],
  not_match = ["npm link"]
)

# AP-005/allow emergency no-verify commit as explicit prompt.
prefix_rule(
  decision = "prompt",
  pattern = ["git", "commit", "--no-verify"],
  match = ["git commit --no-verify -m \"docs: fallback\""],
  not_match = ["git commit -m \"docs: normal\""]
)

prefix_rule(
  decision = "forbidden",
  pattern = ["git", "reset", "--hard"],
  match = ["git reset --hard"],
  not_match = ["git reset --soft"]
)

prefix_rule(
  decision = "forbidden",
  pattern = ["rm", "-rf"],
  match = ["rm -rf /"],
  not_match = ["rm -r ./safe-temp"]
)
