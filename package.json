{
  "name": "@kamishino/kamiflow-core",
  "version": "0.6.0",
  "description": "Standalone Kami Flow Core Codex skill with a minimal installer.",
  "type": "module",
  "bin": {
    "kamiflow-core": "bin/kamiflow-core.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "validate": "node scripts/validate-skill.mjs",
