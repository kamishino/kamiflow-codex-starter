{
  "name": "@kamishino/kfc-chat",
  "version": "0.1.0",
  "description": "Web-first bound Codex session chat utility.",
  "type": "module",
  "bin": {
    "kfc-chat": "bin/kfc-chat.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build:server": "tsc -p tsconfig.json",
    "build:client": "node scripts/build-client.mjs",
    "build": "npm run build:server && npm run build:client",
    "serve": "npm run build && node bin/kfc-chat.js serve",
    "test": "npm run build && node test/run.mjs"
  },
  "dependencies": {
    "@kamishino/kfc-web-ui": "file:../kfc-web-ui",
    "@preact/signals": "2.5.1",
    "eta": "3.5.0",
    "fastify": "5.6.1",
    "preact": "10.26.5",
    "ws": "8.18.3"
  },
  "devDependencies": {
    "@types/node": "22.13.10",
    "typescript": "5.8.2"
  },
  "license": "UNLICENSED"
}
