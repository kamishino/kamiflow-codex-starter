<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= it.title %></title>
  <%~ it.headAssetHtml || "" %>
</head>
<body>
  <div id="app-root"
    data-project-name="<%= it.projectName %>"
    data-project-dir="<%= it.projectDir %>"
    data-api-base="<%= it.apiBase || '/api/chat' %>"
    data-ws-path="<%= it.wsPath || '/ws' %>"></div>
  <%~ it.moduleScriptHtml || "" %>
</body>
</html>
