{
  "name": "@kamishino/kamiflow-plan-ui",
  "version": "0.1.0",
  "description": "Standalone private plan UI CLI for Kami Flow projects.",
  "type": "module",
  "bin": {
    "kfp": "bin/kfp.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "kfp": "npm run build && node bin/kfp.js",
    "start": "npm run kfp --",
    "serve": "npm run kfp -- serve",
    "test": "npm run build && node test/run.mjs"
  },
  "dependencies": {
    "@kamishino/kamiflow-codex": "file:../..",
    "chokidar": "4.0.3",
    "eta": "3.5.0",
    "fastify": "5.6.1"
  },
  "devDependencies": {
    "@types/node": "22.13.10",
    "typescript": "5.8.2"
  },
  "files": [
    "bin",
    "dist",
    "templates",
    "README.md"
  ],
  "license": "UNLICENSED"
}
