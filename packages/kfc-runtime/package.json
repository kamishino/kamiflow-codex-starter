{
  "name": "@kamishino/kfc-runtime",
  "version": "0.1.0",
  "description": "Shared runtime/domain helpers for KFC packages.",
  "type": "module",
  "main": "dist/session-actions.js",
  "exports": {
    "./session-actions": {
      "types": "./src/session-actions.ts",
      "default": "./dist/session-actions.js"
    },
    "./plan-workspace": {
      "types": "./src/plan-workspace.ts",
      "default": "./dist/plan-workspace.js"
    },
    "./project-root": {
      "types": "./src/project-root.ts",
      "default": "./dist/project-root.js"
    },
    "./codex-runner": {
      "types": "./src/codex-runner.ts",
      "default": "./dist/codex-runner.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "22.13.10",
    "typescript": "5.8.2"
  },
  "license": "UNLICENSED"
}
