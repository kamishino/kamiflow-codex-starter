{
  "name": "@kamishino/kfc-session",
  "version": "0.1.0",
  "description": "Web-first Codex session manager utility.",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "kfc-session": "bin/kfc-session.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build:client": "npm run -w @kamishino/kfc-web-runtime build && node scripts/build-client.mjs",
    "build:server": "npm --prefix ../.. run build:server && npm run -w @kamishino/kfc-web-runtime build && tsc -p tsconfig.json",
    "build": "npm run build:server && npm run build:client",
    "serve": "npm run build && node bin/kfc-session.js serve",
    "test": "npm run build && node test/run.mjs"
  },
  "dependencies": {
    "eta": "3.5.0",
    "fastify": "5.6.1"
  },
  "devDependencies": {
    "@types/node": "22.13.10",
    "typescript": "5.8.2"
  },
  "license": "UNLICENSED"
}
